# Groq API (obrigatório) - https://console.groq.com/keys
GROQ_API_KEY=gsk_xxx_sua_chave_aqui

# Modelo Groq (opcional, default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Orçamento de tokens por minuto (opcional, default: 6000 - free tier)
GROQ_TPM_BUDGET=6000

# ScrapingBee API (opcional, para sites com JavaScript: Google Reviews, etc.)
# https://www.scrapingbee.com/ - free tier: 1000 chamadas/mês
SCRAPINGBEE_API_KEY=

# Nível de log (opcional: DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
